{
  "manifest_version": 3,
  "name": "Prod Shield",
  "version": "1.0.0",
  "description": "Disables buttons and tracks field changes on specific domains.",
  "browser_specific_settings": {
    "gecko": {
      "id": "prodshield@extension",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["storage", "tabs", "activeTab", "alarms"],
  "host_permissions": ["*://*/*"],
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
